{
  "name": "global-emobility-id-registry",
  "version": "0.1.0",
  "private": true,
  "description": "Independent aggregation pipeline for e-mobility identifiers from official IDRO registries.",
  "bin": {
    "registry": "./dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "vp check && bun run test && bun run registry:validate",
    "format": "vp fmt --write",
    "format:check": "vp fmt --check",
    "lint": "vp lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "commit:check": "commitlint",
    "registry": "node --import tsx src/cli.ts",
    "registry:update": "node --import tsx src/cli.ts update",
    "registry:validate": "node --import tsx src/cli.ts validate",
    "audit": "bun audit"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "commander": "^14.0.2",
    "read-excel-file": "^9.2.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/node": "^24.10.1",
    "fflate": "^0.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.24",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.13"
}
